[importlinter]
root_package = captioner
include_external_packages = true

[importlinter:contract:layers]
name = Presentation and core layers
type = layers
layers =
    captioner.gui
    captioner.cli
    captioner.core.application
    captioner.core.domain

[importlinter:contract:domain-forbidden]
name = Domain has no presentation or adapter dependencies
type = forbidden
source_modules =
    captioner.core.domain
forbidden_modules =
    captioner.gui
    captioner.cli
    captioner.adapters
    PySide6
    openai
    faster_whisper
    torch
    transformers

[importlinter:contract:application-forbidden]
name = Application has no GUI dependency
type = forbidden
source_modules =
    captioner.core.application
forbidden_modules =
    PySide6
    captioner.gui
    captioner.adapters
    captioner.cli

[importlinter:contract:policies-forbidden]
name = Policies have no external or presentation dependencies
type = forbidden
source_modules =
    captioner.core.policies
forbidden_modules =
    captioner.adapters
    captioner.cli
    captioner.gui
    PySide6
    faster_whisper
    torch
    transformers
    openai

[importlinter:contract:gui-no-cli]
name = GUI does not import CLI
type = forbidden
source_modules =
    captioner.gui
forbidden_modules =
    captioner.cli

[importlinter:contract:cli-no-gui]
name = CLI does not import GUI
type = forbidden
source_modules =
    captioner.cli
forbidden_modules =
    captioner.gui

[importlinter:contract:application-no-adapters]
name = Application does not import adapters
type = forbidden
source_modules =
    captioner.core.application
forbidden_modules =
    captioner.adapters

[importlinter:contract:application-no-cli]
name = Application does not import CLI
type = forbidden
source_modules =
    captioner.core.application
forbidden_modules =
    captioner.cli

[importlinter:contract:adapter-forbidden]
name = Adapters have no GUI dependency
type = forbidden
source_modules =
    captioner.adapters
forbidden_modules =
    captioner.gui

[importlinter:contract:gui-sdk-forbidden]
name = GUI has no model or provider SDK dependency
type = forbidden
source_modules =
    captioner.gui
forbidden_modules =
    faster_whisper
    torch
    transformers
    openai
